# Web/API service container (uWSGI)
FROM localhost/metrics-service-base:latest

# Metadata
LABEL name="metrics-service-web" \
      version="1.0" \
      description="Metrics Service Web/API Server (uWSGI)" \
      component="web"

USER 0

# Install uWSGI
RUN pip install --no-cache-dir uwsgi

USER 1001

# Copy uWSGI configuration
COPY --chown=1001:0 deployment/uwsgi/metrics-service-http.ini /opt/app-root/etc/uwsgi.ini

# Expose port
EXPOSE 8000

# Health check for web service
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/api/health/ || exit 1

# Run uWSGI
CMD ["uwsgi", "--ini", "/opt/app-root/etc/uwsgi.ini"]
